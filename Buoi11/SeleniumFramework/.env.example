# Environment variables - KHONG commit gia tri that vao Git!
# Copy file nay thanh .env va dien gia tri thuc

# SauceDemo credentials
SAUCEDEMO_USERNAME=standard_user
SAUCEDEMO_PASSWORD=secret_sauce

# Selenium Grid URL (bo trong neu chay local)
GRID_URL=

# Ket noi Allure server (optional)
ALLURE_SERVER_URL=
